# Copy this file to scripts/deploy.env on the VPS, then edit the values.

# Domains
API_DOMAIN=api.portalsi.com
WEB_DOMAIN=portalsi.com
WEB_ALIASES=www.portalsi.com

# Project paths on VPS
APP_ROOT=/var/www/portal-si
BACKEND_DIR=/var/www/portal-si/api-portalsi
FRONTEND_DIR=/var/www/portal-si/frontend

# Laravel
APP_ENV=production
APP_DEBUG=false
FILESYSTEM_DISK=public
CORS_ALLOWED_ORIGINS=https://portalsi.com,https://www.portalsi.com

# Database
DB_DATABASE=portalsi
DB_USERNAME=portal_user
DB_PASSWORD=change_this_strong_password

# Optional: set to 1 if you want the script to run apt install.
INSTALL_SYSTEM_PACKAGES=1

# Optional: set to 1 after DNS already points to the VPS.
ENABLE_SSL=0
SSL_EMAIL=admin@portalsi.com

# Optional: set to 1 if Flutter is installed on the VPS and you want the VPS
# to build the frontend. If 0, upload/copy build/web to $FRONTEND_DIR first.
BUILD_FRONTEND_ON_VPS=0

# Optional: set to 1 to enable Laravel queue worker via supervisor.
ENABLE_QUEUE_WORKER=1
