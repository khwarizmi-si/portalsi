PUBLIC_APP_NAME=Portal SI
API_BASE_URL=https://api.portalsi.com
PUBLIC_MEDIA_BASE_URL=https://api.portalsi.com/storage
PUBLIC_REVERB_HOST=ws.portalsi.com
PUBLIC_REVERB_PORT=443
PUBLIC_REVERB_SCHEME=wss
PUBLIC_REVERB_APP_KEY=

# Adapter Node (production behind reverse proxy)
# PORT harus sama dengan address di deploy-vps/vhost-proxy.conf (127.0.0.1:3100).
HOST=127.0.0.1
PORT=3100
ORIGIN=https://app.portalsi.com
BODY_SIZE_LIMIT=512M
NODE_ENV=production

# Server-only. Never prefix secrets with PUBLIC_.
RANKING_API_URL=https://santriboard.vercel.app/api/student/leaderboard
AUDIUS_API_URL=https://api.audius.co/v1/tracks/search
AUDIUS_APP_NAME=portal-si
NOMINATIM_API_URL=https://nominatim.openstreetmap.org
